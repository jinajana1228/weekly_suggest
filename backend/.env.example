# ── 실행 환경 ─────────────────────────────────────────────────
# development | production
# 주의: ENV는 POSIX 예약 변수 (컨테이너에서 /etc/profile 등으로 설정됨)
# Railway 배포 시에는 반드시 APP_ENV를 사용할 것
APP_ENV=development

# 로그 레벨 (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# ── 데이터 제공자 ─────────────────────────────────────────────
# mock | fmp | yfinance | hybrid
DATA_PROVIDER_MODE=mock
MOCK_DATA_DIR=../data/mock

# FMP API (fmp 또는 hybrid 모드에서 필요)
FMP_API_KEY=your_fmp_api_key_here

# ── LLM Narrative 생성 ────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
NARRATIVE_MODEL=claude-sonnet-4-6
NARRATIVE_REQUIRE_FOR_PUBLISH=False

# ── CORS ─────────────────────────────────────────────────────
# 로컬 개발: localhost 포트 목록 (쉼표 구분)
# 배포 시: 실제 프론트엔드 도메인으로 교체
# 예: CORS_ORIGINS=https://weekly-suggest.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Admin 보호 ────────────────────────────────────────────────
# 로컬 개발: 빈 값 = 인증 없음
# 배포 시: 반드시 임의의 긴 랜덤 문자열로 설정
# 예: openssl rand -hex 32
ADMIN_API_KEY=

# ── 스토리지 경로 오버라이드 ──────────────────────────────────
# 로컬 개발: 빈 값 = __file__ 기반 자동 해석 (weekly_suggest/data/)
# Railway Volume 사용 시:
#   STATE_DB_PATH=/data/state.db
#   MOCK_DATA_DIR=/data/mock
STATE_DB_PATH=
# MOCK_DATA_DIR 기본값: ../data/mock (file_store.py가 절대경로로 해석)
MOCK_DATA_DIR=../data/mock

# ── 발행 정책 ─────────────────────────────────────────────────
MIN_PUBLISH_STOCKS=5
MAX_DATA_QUALITY_FLAGS=3
DATA_FRESHNESS_THRESHOLD_HOURS=72
