# ── Data Provider ─────────────────────────────────────────────
# 사용할 데이터 제공자 선택: mock | fmp | yfinance | hybrid
# mock  : 내장 목업 데이터 (API 키 불필요, 로컬 개발용)
# fmp   : Financial Modeling Prep 실데이터 (FMP_API_KEY 필요)
# yfinance: Yahoo Finance 무료 API (pip install yfinance 필요)
# hybrid: yfinance 가격 + FMP 컨센서스 혼합
DATA_PROVIDER_MODE=mock

# FMP API 키 (fmp / hybrid 모드에서만 필요)
# 발급: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=

# ── Admin ─────────────────────────────────────────────────────
# Admin API 보호 키 (빈 값이면 인증 없음 -- 로컬 개발용)
ADMIN_API_KEY=

# ── Application ───────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
