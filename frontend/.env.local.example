# ── 백엔드 API URL (SSR fetch 용) ────────────────────────────
# 로컬 개발 시 주석 처리 또는 생략 (자동으로 http://localhost:8000 사용)
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# 배포 시 서버사이드 SSR fetch 에 사용되는 백엔드 URL (public endpoint)
# Vercel에서는 아래처럼 설정한다 (NEXT_PUBLIC_ 이면 브라우저에도 노출됨에 주의)
# NEXT_PUBLIC_API_URL=https://weekly-suggest-api.railway.app/api/v1

# ── 백엔드 URL (Next.js rewrite 경유 서버용) ──────────────────
# next.config.mjs 의 rewrite destination 에 사용됨
# 클라이언트 사이드 요청은 항상 /api/v1 (rewrite) 경유
# BACKEND_URL=https://weekly-suggest-api.railway.app
