# ── 프론트엔드 (Vercel 별도 배포) ────────────────────────────
frontend/

# ── Python 가상환경 및 캐시 ───────────────────────────────────
backend/venv/
backend/__pycache__/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# ── 로컬 환경설정 (빌드 이미지에 포함하지 않음) ──────────────
