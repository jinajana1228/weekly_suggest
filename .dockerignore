**/.env.local
**/.env.*.local
backend/.env

# ── Git / IDE ─────────────────────────────────────────────────
.git/
.gitignore
.gitattributes
**/.DS_Store

# ── 문서 (이미지 크기 절약) ──────────────────────────────────
docs/

# ── Node 의존성 ───────────────────────────────────────────────
node_modules/
